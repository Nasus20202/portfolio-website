---
import { personalInfo } from '../data';
import Icon from './Icon.astro';
---

<section id="about" class="scroll-mt-24">
  <div class="mb-8">
    <h1
      class="text-4xl font-bold tracking-tight text-white sm:text-5xl hover:text-emerald-400 transition-colors"
    >
      {personalInfo.name}
    </h1>
    <h2 class="mt-3 text-lg font-mono text-zinc-400">
      <span class="text-violet-400 mr-2">&gt;</span>
      {personalInfo.role} @ {personalInfo.company}
    </h2>
  </div>

  <div class="prose prose-invert max-w-none text-zinc-400">
    <p class="leading-relaxed" set:html={personalInfo.bio} />
  </div>

  <ul class="mt-8 flex flex-col gap-4" aria-label="Social links">
    {
      personalInfo.socials.map((social) => {
        return (
          <li class="flex">
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-center gap-4 text-sm font-medium text-zinc-400 hover:text-white transition-colors w-full"
              aria-label={`${social.name} ${social.displayText || social.url} (opens in a new tab)`}
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-md bg-zinc-800/50 ring-1 ring-inset ring-zinc-700/50 transition-colors group-hover:bg-zinc-800 group-hover:text-emerald-400">
                <Icon slug={social.iconSlug as never} className="h-5 w-5" colorful={false} />
              </span>
              <div class="flex flex-col">
                <span class="text-xs text-zinc-500 font-mono">{social.name}</span>
                <span class="text-zinc-300 font-mono group-hover:text-emerald-400 transition-colors">
                  {social.displayText || social.url}
                </span>
              </div>
            </a>
          </li>
        );
      })
    }
  </ul>
</section>
